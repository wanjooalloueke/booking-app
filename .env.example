# Configuration de la base de données
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=password
DB_NAME=booking_app
DB_PORT=3306

# Configuration du serveur
PORT=5000
NODE_ENV=development

# Clé secrète JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Expiration du token JWT (en heures)
JWT_EXPIRE=24

# URLs (adapter si port différent)
BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5507

# Origines CORS supplémentaires (séparées par des virgules)
# Exemple production: https://booking-ci.onrender.com
CORS_ORIGINS=

# ─── GOOGLE OAUTH ──────────────────────────────────────────────────────────────
# 1. Allez sur https://console.cloud.google.com/
# 2. Créez un projet → APIs & Services → Credentials → Create OAuth 2.0 Client ID
# 3. Type: Web application
# 4. Authorized redirect URIs: http://localhost:5000/api/auth/google/callback
GOOGLE_CLIENT_ID=votre_google_client_id_ici
GOOGLE_CLIENT_SECRET=votre_google_client_secret_ici

# ─── FACEBOOK OAUTH ────────────────────────────────────────────────────────────
# 1. Allez sur https://developers.facebook.com/
# 2. Créez une App → Facebook Login → Web
# 3. Valid OAuth Redirect URIs: http://localhost:5000/api/auth/facebook/callback
FACEBOOK_APP_ID=votre_facebook_app_id_ici
FACEBOOK_APP_SECRET=votre_facebook_app_secret_ici

# ─── APPLE SIGN IN ─────────────────────────────────────────────────────────────
# Nécessite un compte Apple Developer ($99/an) et un domaine HTTPS
# 1. Apple Developer → Certificates → Identifiers → Services IDs
# 2. Activez Sign In with Apple, configurez le domaine et Redirect URL
# 3. Créez une clé privée (.p8) dans Keys
# Note: Apple Sign In ne fonctionne PAS sur http://localhost (HTTPS requis)
APPLE_CLIENT_ID=votre.service.id.apple
APPLE_TEAM_ID=votre_team_id
APPLE_KEY_ID=votre_key_id
APPLE_PRIVATE_KEY_PATH=./backend/config/AuthKey_VOTRE_KEY_ID.p8
